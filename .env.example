# Создайте .env.local только для локальной разработки. Не коммитьте реальные значения.
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TRANSCRIBE_MODEL=gemini-3.5-flash
# Для возврата к OpenAI установите AI_PROVIDER=openai и заполните две строки ниже.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
